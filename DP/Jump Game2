//using recursion
class Solution {
public:
int solve(int index,vector<int>& nums,int n)
{
    //base case
    //(if you reach at the last index)
    //you cannot jump from there(means no jump)
    if(index==n-1)
    return 0;
    //edge case
    if(index>=n)
    return INT_MAX;
    int maxJump=nums[index];
    //edge case
    if(nums[index]==0)
    return INT_MAX;
     //we want to return min jump to reach at end
    int minJum=INT_MAX;
    for(int jumpi=1;jumpi<=maxJump;jumpi++)
    {
        int jump=solve(index+jumpi,nums,n);//index=3,in that case jump=0(because it return 0)
        if(jump!=INT_MAX)
        minJum=min(minJum,1+jump);//but actually we take a jump of 1 due to this we add extra 1
    }
    return minJum;
}
    int jump(vector<int>& nums) {
        int n=nums.size();
        int minJump=solve(0,nums,n);
        return minJump;   
    }
};
//using memorization dp 
class Solution {
public:
int solve(int index,vector<int>& nums,int n,vector<int>&dp)
{
     //base case
    //(if you reach at the last index)
    //you cannot jump from there(means no jump)
    if(index==n-1)
    return 0;
     //edge case
    if(index>=n)
    return INT_MAX;
    //edge case
    if(nums[index]==0)
    return INT_MAX;
    //extra work of dp
    if(dp[index]!=-1)
    return dp[index];
    int maxJump=nums[index];

     //we want to return min jump to reach at end
    int minJum=INT_MAX;
    for(int jumpi=1;jumpi<=maxJump;jumpi++)
    {
        int jump=solve(index+jumpi,nums,n,dp);//index=3,in that case jump=0(because it return 0)
        if(jump!=INT_MAX)
        minJum=min(minJum,1+jump);//but actually we take a jump of 1 due to this we add extra 1
        //store minJump first
        dp[index]=minJum;
    }
    return minJum;
}
    int jump(vector<int>& nums) {
        int n=nums.size();
        vector<int>dp(n,-1);
        int minJump=solve(0,nums,n,dp);
        return minJump;   
    }
};
//using tabulation dp
class Solution {
public:
    int jump(vector<int>& nums) {
        int n=nums.size();
        vector<int>dp(n,-1);
        dp[n-1]=0;
        for(int i=n-2;i>=0;i--)
        {
            int maxJump=nums[i];
            int minJum=INT_MAX;
            for(int jumpi=1;jumpi<=maxJump;jumpi++)
            {
                if(i+jumpi<n && dp[i+jumpi]!=-1)
                {
                    int jump=dp[i+jumpi];
                    minJum=min(minJum,1+jump);
                }
            }
            //store min jump value for i
            if(minJum!=INT_MAX)
            dp[i]=minJum;
        } 
        return dp[0];
    }
};
