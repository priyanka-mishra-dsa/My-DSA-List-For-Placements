class Solution {
public:
    long long countBadPairs(vector<int>& nums) {
        long long n=nums.size();
        long long badPairs=0;
        //convert into nums[i]-i!= nums[j]-j
        for(int i=0;i<n;i++)
        {
            nums[i]=nums[i]-1;
        }
        //take map to store freq of previous element
        unordered_map<int,int>m;
        //for each j we will check left side j 
        m[nums[0]]++;
        for(int j=1;j<n;j++)
        {
            int totalNoBeforej=j;
            int badPairs=badPairs+totalNoBeforej-m[nums[j]];
            //add freq of current element in the map
            m[nums[j]]++;
        }
        return badPairs;
    }
};
